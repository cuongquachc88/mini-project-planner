# Google OAuth2 credentials for Drive sync
# Create at: https://console.cloud.google.com/apis/credentials (type: Web application)
# Enable: Google Drive API, scope: https://www.googleapis.com/auth/drive.appdata
# Set redirect URIs: http://localhost:5174/oauth-callback and your production URL
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your-client-secret
