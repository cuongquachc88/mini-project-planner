# Google OAuth2 client ID for Drive sync
# Create at: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: http://localhost:5173/oauth-callback (dev) and your production URL
# Enable: Google Drive API, scope: https://www.googleapis.com/auth/drive.appdata
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
